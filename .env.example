# Copy to .env.local and fill in. Never commit .env.local.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI TTS for the warm female voice in voice mode.
# Without this, voice mode falls back to the browser's built-in (robotic) voice.
# Get a key at: https://platform.openai.com/api-keys
# Cost: ~$0.006 per voice reply. Personal use will be pennies/month.
OPENAI_API_KEY=sk-...

# Optional. Defaults to nova (warm female) if unset.
# Other warm options: shimmer (brighter female), fable (British female).
OPENAI_TTS_VOICE=nova
